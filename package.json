{
  "name": "survey-api",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:glesiosantos/survey-api.git",
  "author": "glesiosantos <glesioss@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "node build/main/server.js",
    "build": "rimraf build && tsc",
    "prepare": "husky install",
    "dev": "sucrase-node src/main/server.ts",
    "test": "jest --passWithNoTests --runInBand --no-cache",
    "test:verbose": "jest --passWithNoTests --runInBand",
    "test:unit": "npm test -- --watch -c jest_unit.config.js",
    "test:inte": "npm test -- --watch -c jest_inte.config.js",
    "test:staged": "npm test -- --findRelatedTests",
    "test:ci": "npm test -- --coverage"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^4.1.7",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^20.4.0",
    "@types/supertest": "^2.0.12",
    "@types/validator": "^13.7.17",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "eslint": "^8.0.1",
    "eslint-config-standard-with-typescript": "^36.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "git-commit-msg-linter": "^5.0.4",
    "husky": "^8.0.3",
    "jest": "^29.6.1",
    "lint-staged": "^13.2.3",
    "rimraf": "^5.0.5",
    "sucrase": "^3.34.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^5.7.0",
    "validator": "^13.9.0"
  }
}
